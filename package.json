{
  "name": "nkurunziza-docs",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "sideEffects": [
    "styles/*.css"
  ],
  "bin": {
    "nkurunziza-docs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "styles/mdx-components.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js",
      "require": "./dist/components.js",
      "default": "./dist/components.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./styles/mdx-components.css": "./styles/mdx-components.css"
  },
  "scripts": {
    "dev": "next dev",
    "generate-search": "tsx scripts/generate-search-data.ts",
    "build": "pnpm run generate-search && next build",
    "build:lib": "tsup",
    "prepublishOnly": "pnpm run build:lib",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-beta.3",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.4",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.544.0",
    "yaml": "^2.8.1",
    "next": "^15.5.4",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@shikijs/rehype": "^3.13.0",
    "@shikijs/transformers": "^3.13.0",
    "@tailwindcss/postcss": "^4",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "hastscript": "^9.0.1",
    "mdast-util-directive": "^3.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "shiki": "^3.13.0",
    "tailwindcss": "^4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "next": "^15 || ^16",
    "next-themes": "^0.4.6",
    "@mdx-js/react": "^3"
  }
}
